# Supply-chain cooldown: only install package versions that have been
# published for at least this many days. Guards against installing a
# freshly-compromised release. (npm >= 11.5)
min-release-age=7

# Block lifecycle scripts (preinstall / install / postinstall) from
# every package on install. Primary attack vector for npm supply-chain
# compromises — disabling forces any binary fetch or native rebuild
# to be explicit.
#
# One package in our tree needs an out-of-band install step:
# @playwright/test, which downloads browser binaries via its
# postinstall. That step is wrapped in the `setup` npm script in
# package.json — run `npm run setup` for a usable install instead
# of bare `npm ci`. (Vite 8's bundler Rolldown uses optionalDependencies
# for platform binaries and needs no postinstall.)
ignore-scripts=true
